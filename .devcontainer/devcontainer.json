{
  "name": "MyDispatch Codespace",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:0-20",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "settings": {
    "editor.formatOnSave": true,
    "files.eol": "\n"
  },
  "forwardPorts": [5173, 5177, 5192],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server" },
    "5177": { "label": "Alt Dev Server" },
    "5192": { "label": "Preview Server" }
  },
  "postCreateCommand": "npm ci",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.copilot",
        "github.copilot-chat",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "containerEnv": {
    "VITE_SUPABASE_URL": "${localEnv:VITE_SUPABASE_URL}",
    "VITE_SUPABASE_ANON_KEY": "${localEnv:VITE_SUPABASE_ANON_KEY}",
    "GOOGLE_SERVICE_ACCOUNT_EMAIL": "${localEnv:GOOGLE_SERVICE_ACCOUNT_EMAIL}",
    "GOOGLE_PRIVATE_KEY": "${localEnv:GOOGLE_PRIVATE_KEY}"
  }
}
