# ENVIRONMENT VARIABLES - EXAMPLE FILE
# Kopiere diese Datei zu .env.local und füge deine echten Keys ein
# ⚠️ WICHTIG: .env.local ist in .gitignore und wird NICHT committet!

# ============================================
# SUPABASE
# ============================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Optional: falls ein anderer Key-Name genutzt wird
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_PUBLISHABLE_KEY
# Hinweis: Keine Backticks oder Anführungszeichen verwenden, nur den reinen Wert.

# Backend-Only (nicht im Browser, nicht in Build exportiert)
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Hinweis:
# - Nur lokal für Skripte/Tests verwenden (node scripts/*)
# - In Produktion als Secret speichern (Supabase Functions/GitHub/Vercel)
# - Niemals in Client-Code referenzieren, keine VITE_* Präfixe verwenden

# ============================================
# GOOGLE APIs
# ============================================
VITE_GOOGLE_API_KEY=AIzaSy...

# ============================================
# DAILY API
# ============================================
VITE_DAILY_API_KEY=e4397b97b3227ce33788210723d0454edfbbb4bc487efe01ec372ca8cc441d72

# ============================================
# STRIPE (Payment)
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_...

# ============================================
# HERE Maps
# ============================================
VITE_HERE_API_KEY=...

# ============================================
# SENTRY (Error Tracking)
# ============================================
VITE_SENTRY_DSN=https://...

# ============================================
# VERCEL (Deployment)
# ============================================
# Diese Werte als GitHub/Vercel Secrets setzen, NICHT in .env.local!
# VERCEL_PROJECT_ID=prj_j6exywYDPrstYDQvd2XEQMeIDQZt
# VERCEL_ORG_ID=u4231458123-droid
# VERCEL_TOKEN=4o3cHB4R5bPVzfp3fFiTLV77

# ============================================
# FRONTEND BASE PATH (für Subpfad-Deployments)
# ============================================
# Standard: '/'. Wenn die App unter z.B. /master/ läuft, setze:
# VITE_BASE_PATH=/master/


# ============================================
# ANTHROPIC (Claude) - für Edge Functions
# ============================================
# Wird in Supabase Secrets gespeichert, nicht hier!

